generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissionCategory {
  CASUAL_BROWSER
  EARLY_INTEREST
  CONSIDERATION_STAGE
  SERIOUS_BUYER
  HIGH_INTENT_BUYER
}

enum OutcomeStatus {
  CONTACTED
  QUALIFIED
  VISIT_BOOKED
  FINANCE_APPLIED
  CONVERTED
  REJECTED
  JUNK
}

enum RuleDirection {
  POSITIVE
  NEGATIVE
}

enum ScoreLayer {
  BEHAVIOURAL
  INTERACTION
  DEMAND
  CONSISTENCY
  READINESS
}

enum DealerMatchStatus {
  PENDING
  MATCHED
  UNMATCHED
  MANUAL_REVIEW
}

enum RoutingStatus {
  CAPTURED
  READY_FOR_ASSIGNMENT
  ASSIGNED
}

model Submission {
  id                 String                @id @default(cuid())
  industry           String
  financePreference  String?
  purchaseTimeline   String?
  purchaseReason     String?
  testDriveReadiness String?
  scoreVersion       String
  weightVersion      String
  ruleSetVersion     String
  currentOutcomeStatus OutcomeStatus?
  outcomeUpdatedAt   DateTime?
  rawPayload         Json
  normalizedAnswers  Json
  webhookEvent       Json
  totalScore         Int
  category           SubmissionCategory
  positives          Json
  negatives          Json
  recommendedAction  String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  scoreBreakdown     ScoreBreakdown?
  behaviouralMetrics BehaviouralMetrics?
  metadata           LeadMetadata?
  routingProfile     DealerRoutingProfile?
  consentRecord      SubmissionConsent?
  ruleContributions  RuleContribution[]
  outcomes           SubmissionOutcome[]

  @@index([industry, totalScore])
  @@index([category, createdAt])
  @@index([financePreference, purchaseTimeline])
  @@index([currentOutcomeStatus, outcomeUpdatedAt])
}

model AnalyticsSnapshot {
  id                  String   @id @default(cuid())
  snapshotDate        String   @unique
  generatedAt         DateTime
  totalSubmissions    Int
  labeledSubmissions  Int
  convertedSubmissions Int
  payload             Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([snapshotDate])
}

model ScoreBreakdown {
  id                String     @id @default(cuid())
  submissionId      String     @unique
  behaviouralScore  Int
  interactionScore  Int
  demandScore       Int
  consistencyScore  Int
  readinessScore    Int
  submission        Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model BehaviouralMetrics {
  id                     String     @id @default(cuid())
  submissionId           String     @unique
  totalCompletionSeconds Int?
  timePerStepSeconds     Json?
  backtracks             Int?
  answerEdits            Int?
  idlePauses             Int?
  tabSwitches            Int?
  scrollDepthPercent     Int?
  completionRatePercent  Int?
  submission             Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model LeadMetadata {
  id           String     @id @default(cuid())
  submissionId String     @unique
  source       String?
  campaign     String?
  formId       String?
  sessionId    String?
  channel      String?
  sdkVersion   String?
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model DealerRoutingProfile {
  id                String            @id @default(cuid())
  submissionId      String            @unique
  pincode           String
  city              String
  locality          String
  addressLine       String?
  assignedDealerId  String?
  matchedDealerName String?
  dealerMatchStatus DealerMatchStatus @default(PENDING)
  routingStatus     RoutingStatus     @default(CAPTURED)
  matchedAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  submission        Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([pincode, city])
  @@index([dealerMatchStatus, routingStatus])
}

model SubmissionConsent {
  id                   String     @id @default(cuid())
  submissionId         String     @unique
  dealerContactConsent Boolean
  consentedAt          DateTime
  privacyNoticeVersion String?
  consentSource        String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  submission           Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model IndustryModel {
  id                 String   @id @default(cuid())
  slug               String   @unique
  displayName        String
  version            String
  supportedQuestions Json
  scoreBands         Json
  config             Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RuleContribution {
  id               String        @id @default(cuid())
  submissionId     String
  sequence         Int
  ruleCode         String
  layer            ScoreLayer
  direction        RuleDirection
  points           Int
  reason           String
  signalCategories String[]
  createdAt        DateTime      @default(now())
  submission       Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, sequence])
  @@index([ruleCode])
  @@index([layer])
}

model SubmissionOutcome {
  id           String        @id @default(cuid())
  submissionId String
  status       OutcomeStatus
  note         String?
  source       String?
  happenedAt   DateTime
  createdAt    DateTime      @default(now())
  submission   Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, happenedAt])
  @@index([status, happenedAt])
}
